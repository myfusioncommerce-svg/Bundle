{% assign target_product = block.settings.manual_product | default: product %}
{% assign configs = shop.metafields.bundle_builder.bxgy_config.value %}
{% assign config = nil %}
{% assign is_buy_product = false %}

{% if configs and target_product %}
  {% assign current_product_id = target_product.id | append: "" %}
  
  {% comment %} 
    The app saves an array of bundles. We iterate to find the first match.
    We also handle the legacy single-object format just in case.
  {% endcomment %}
  {% if configs.buyProducts %}
    {% assign first_bundle = configs %}
    {% for p in first_bundle.buyProducts %}
      {% assign config_id = p.id | split: '/' | last %}
      {% if p.handle == target_product.handle or config_id == current_product_id %}
        {% assign is_buy_product = true %}
        {% assign config = first_bundle %}
        {% break %}
      {% endif %}
    {% endfor %}
  {% else %}
    {% for bundle in configs %}
      {% for p in bundle.buyProducts %}
        {% assign config_id = p.id | split: '/' | last %}
        {% if p.handle == target_product.handle or config_id == current_product_id %}
          {% assign is_buy_product = true %}
          {% assign config = bundle %}
          {% break %}
        {% endif %}
      {% endfor %}
      {% if is_buy_product %}{% break %}{% endif %}
    {% endfor %}
  {% endif %}
{% endif %}

{% if request.design_mode %}
  {% if target_product == blank %}
    <div style="padding: 20px; background: #fff4f4; border: 1px dashed #ff0000; border-radius: 8px; text-align: center;">
      <strong>BXGY Debug:</strong> No product detected. Use <strong>Manual Product Selection</strong> in settings.
    </div>
  {% elsif configs == blank %}
    <div style="padding: 20px; background: #fff4f4; border: 1px dashed #ff0000; border-radius: 8px; text-align: center;">
      <strong>BXGY Debug:</strong> App settings not found. Metafield <code>bundle_builder.bxgy_config</code> is empty.
    </div>
  {% elsif is_buy_product == false %}
    <div style="padding: 20px; background: #f4faff; border: 1px dashed #0088ff; border-radius: 8px; text-align: center;">
      <strong>BXGY Debug Info:</strong><br>
      Product: "{{ target_product.title }}" ({{ target_product.handle }})<br>
      ID: {{ target_product.id }}<br>
      Status: Not in any "Buy" list.<br>
      <em>Go to the app and add this product to a Buy X Get Y bundle.</em>
    </div>
  {% endif %}
{% endif %}

{% if is_buy_product and config %}
  <style>
    .bxgy-container {
      margin: 20px 0;
      padding: 20px;
      border: 2px solid {{ block.settings.accent_color | default: '#000' }};
      border-radius: 8px;
      background: {{ block.settings.accent_color | color_modify: 'alpha', 0.05 }};
    }
    .bxgy-title {
      font-weight: bold;
      font-size: 1.2em;
      margin-bottom: 10px;
    }
    .bxgy-details {
      margin-bottom: 15px;
      font-size: 0.95em;
    }
    .bxgy-button {
      width: 100%;
      padding: 12px;
      background: {{ block.settings.accent_color | default: '#000' }};
      color: white;
      border: none;
      border-radius: 4px;
      font-weight: bold;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: opacity 0.2s;
    }
    .bxgy-button:disabled {
      opacity: 0.7;
      cursor: not-allowed;
    }
    .btn-spinner {
      display: inline-block;
      width: 18px;
      height: 18px;
      border: 2px solid rgba(255, 255, 255, 0.3);
      border-radius: 50%;
      border-top-color: #fff;
      animation: bxgy-spin 1s ease-in-out infinite;
      margin-right: 8px;
    }
    @keyframes bxgy-spin {
      0% { transform: rotate(0deg); }
      100% { transform: rotate(360deg); }
    }
    .bxgy-gift-selector {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      margin-top: 10px;
    }
    .bxgy-gift-card {
      width: 90px;
      border: 2px solid #eee;
      border-radius: 6px;
      padding: 8px;
      cursor: pointer;
      text-align: center;
      transition: all 0.2s;
      background: #fff;
      display: flex;
      flex-direction: column;
      align-items: center;
    }
    .bxgy-gift-card:hover {
      border-color: #ccc;
    }
    .bxgy-gift-card.selected {
      border-color: {{ block.settings.accent_color | default: '#000' }};
      background: {{ block.settings.accent_color | color_modify: 'alpha', 0.05 }};
    }
    .bxgy-gift-card img {
      width: 60px;
      height: 60px;
      object-fit: contain;
      margin-bottom: 5px;
      background: #f9f9f9;
      border-radius: 4px;
    }
    .bxgy-gift-card span {
      font-size: 11px;
      font-weight: 500;
      line-height: 1.2;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
      height: 26px;
    }
  </style>

  <div class="bxgy-container" id="bxgy-{{ section.id }}">
    <div class="bxgy-title">{{ block.settings.heading | default: 'Special Offer!' }}</div>
    
    <div style="display: flex; gap: 15px; align-items: flex-start; margin-bottom: 15px;">
      <div style="width: 80px; height: 80px; flex-shrink: 0; background: #fff; border-radius: 4px; border: 1px solid #eee; overflow: hidden;">
        <img src="{{ target_product.featured_image | img_url: '160x160' }}" style="width: 100%; height: 100%; object-fit: contain;">
      </div>
      <div class="bxgy-details" style="margin-bottom: 0; flex-grow: 1;">
        Buy {{ config.buyCount }} of <strong>"{{ target_product.title }}"</strong><br>
        and get {{ config.getCount }} 
        {% if config.getProducts.size > 1 %}
          of your choice from:
          <div class="bxgy-gift-selector">
            {% for p in config.getProducts %}
              <div class="bxgy-gift-card {% if forloop.first %}selected{% endif %}" 
                   data-handle="{{ p.handle }}" 
                   onclick="BXGYInstance.selectGift(this)">
                <img src="{{ p.image | default: 'https://cdn.shopify.com/s/assets/no-image-2048-5e88c1b20e08c0b79694669573f1a8f237130f1731669ef0741065ac351b0c39_160x160.gif' }}" alt="{{ p.title }}">
                <span>{{ p.title }}</span>
              </div>
            {% endfor %}
          </div>
        {% else %}
          <strong>"{{ config.getProducts[0].title }}"</strong>
        {% endif %}
        
        <div style="margin-top: 10px; color: {{ block.settings.accent_color | default: '#d72c0d' }}; font-weight: bold; font-size: 1.1em;">
          {% if config.discountType == 'free' %}
            FOR FREE!
          {% else %}
            AT {{ config.discountValue }}% OFF!
          {% endif %}
        </div>
      </div>
    </div>
    
    <button class="bxgy-button" onclick="BXGYInstance.buy(this)">Claim This Offer</button>
  </div>

  <script>
    var BXGYInstance = BXGYInstance || (function() {
      const syncWithTheme = {{ block.settings.sync_with_theme | json }};

      if (syncWithTheme) {
        document.addEventListener('click', function(e) {
          const btn = e.target.closest('button[name="add"], .shopify-payment-button__button, [data-testid="Checkout-button"], .add-to-cart, .atc-button, #AddToCart, .product-form__submit, .product-form__cart-submit');
          if (!btn) return;

          const container = document.querySelector('.bxgy-container');
          if (!container) return;

          // Only intercept if we are on a "Buy" product page
          const isBuyProduct = {{ is_buy_product | json }};
          if (!isBuyProduct) return;

          // Determine if this is a "Buy Now" button
          const isCheckout = btn.classList.contains('shopify-payment-button__button') || 
                            btn.getAttribute('data-testid') === 'Checkout-button' ||
                            btn.closest('.shopify-payment-button') ||
                            btn.classList.contains('buy-now-button');

          e.preventDefault();
          e.stopPropagation();
          BXGYInstance.buy(btn, isCheckout);
        }, true);
      }

      return {
        selectGift: function(card) {
          const selector = card.closest('.bxgy-gift-selector');
          selector.querySelectorAll('.bxgy-gift-card').forEach(c => c.classList.remove('selected'));
          card.classList.add('selected');
        },
        buy: async function(button, isCheckout = false) {
          const container = document.querySelector('.bxgy-container');
          
          // Dynamically get current variant ID for the "Buy" product
          const getBuyVariantId = () => {
            const urlParams = new URLSearchParams(window.location.search);
            const variantFromUrl = urlParams.get('variant');
            if (variantFromUrl) return variantFromUrl;

            const variantInput = document.querySelector('form[action*="/cart/add"] input[name="id"], input[name="id"], select[name="id"]');
            if (variantInput && variantInput.value) return variantInput.value;

            return '{{ target_product.selected_or_first_available_variant.id }}';
          };

          const buyVariantId = getBuyVariantId();
          const getProducts = {{ config.getProducts | json }};
          
          if (!getProducts || getProducts.length === 0) {
              if (!isCheckout) alert('Offer configuration error: No "Get" products defined.');
              return;
          }

          let getProductHandle = getProducts[0].handle;
          const selectedGift = container.querySelector('.bxgy-gift-card.selected');
          if (selectedGift) {
            getProductHandle = selectedGift.dataset.handle;
          }
          
          try {
              if (button.tagName === 'BUTTON') {
                button.disabled = true;
                if (button.innerText) button.dataset.oldHtml = button.innerHTML;
                button.innerHTML = '<span class="btn-spinner"></span> ' + (isCheckout ? 'Processing...' : 'Adding Bundle...');
              }

              const response = await fetch('/products/' + getProductHandle + '.js');
              if (!response.ok) throw new Error('Failed to fetch "Get" product data');
              
              const getProductData = await response.json();
              console.log('BXGY: "Get" product data loaded', getProductData);
              const getVariantId = getProductData.variants[0].id;

              // Get quantity from theme if available, otherwise use config.buyCount
              const getThemeQty = () => {
                const qtyInput = document.querySelector('input[name="quantity"], input[id^="Quantity-"], .quantity__input, .qty-input');
                return qtyInput ? parseInt(qtyInput.value) : {{ config.buyCount }};
              };
              
              const currentQty = getThemeQty();
              const buyQty = Math.max(currentQty, {{ config.buyCount }});

              const items = [
                  { id: buyVariantId, quantity: buyQty },
                  { id: getVariantId, quantity: {{ config.getCount }} }
              ];

              const code = 'fubxgy-' + '{{ config.discountType }}' + '-' + '{{ config.discountValue }}';

              if (isCheckout) {
                // For checkout, we use the /cart/ID:QTY,ID:QTY format
                const cartItems = items.map(item => `${item.id}:${item.quantity}`).join(',');
                window.location.href = `/cart/${cartItems}?discount=${encodeURIComponent(code)}`;
              } else {
                await fetch('/cart/add.js', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ items })
                });

                window.location.href = '/discount/' + encodeURIComponent(code) + '?redirect=/checkout';
              }
          } catch (e) {
              console.error('BXGY Error:', e);
              if (!isCheckout) alert('Could not add bundle to cart.');
              if (button.tagName === 'BUTTON') {
                button.disabled = false;
                if (button.dataset.oldHtml) button.innerHTML = button.dataset.oldHtml;
              }
          }
        }
      };
    })();
  </script>
{% endif %}

{% schema %}
{
  "name": "Buy X Get Y",
  "target": "section",
  "settings": [
    {
      "type": "product",
      "id": "manual_product",
      "label": "Manual Product Selection",
      "info": "Use this if the block is on a non-product page or for testing."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Special Offer!"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#000000"
    },
    {
      "type": "checkbox",
      "id": "sync_with_theme",
      "label": "Sync with Theme Buttons",
      "default": false,
      "info": "Automatically intercept the theme's 'Add to Cart' button to apply this BXGY offer."
    }
  ]
}
{% endschema %}
